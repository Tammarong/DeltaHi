generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "service_user", "dbo"]
}

model ServiceUser {
  id         String          @id @db.Uuid
  employeeId String          @map("employee_id") @db.VarChar
  shares     EmployeeShare[]

  @@map("users")
  @@schema("service_user")
}

model HrEmployeeBasicInfo {
  empid     String             @id @db.VarChar
  name      String?            @db.VarChar
  surname   String?            @db.VarChar
  shares    EmployeeShare[]
  downloads EmployeeDownload[]

  @@map("v_HR_EXP_EmpBasicInfo")
  @@schema("dbo")
}

model EmployeeShare {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String              @unique @map("user_id") @db.Uuid
  employeeId String              @map("employee_id") @db.VarChar
  createdAt  DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime?           @map("deleted_at") @db.Timestamptz(6)
  downloads  EmployeeDownload[]
  user       ServiceUser         @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  employee   HrEmployeeBasicInfo @relation(fields: [employeeId], references: [empid], onDelete: Restrict, onUpdate: Cascade)

  @@map("employee_share")
  @@schema("public")
}

model EmployeeDownload {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeShareId  String              @map("employee_share_id") @db.Uuid
  recieverEmpId    String              @map("reciever_emp_id") @db.VarChar
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?           @map("deleted_at") @db.Timestamptz(6)
  share            EmployeeShare       @relation(fields: [employeeShareId], references: [id], onDelete: Restrict)
  receiverEmployee HrEmployeeBasicInfo @relation(fields: [recieverEmpId], references: [empid], onDelete: Restrict, onUpdate: Cascade)

  @@unique([employeeShareId, recieverEmpId])
  @@index([employeeShareId])
  @@index([recieverEmpId])
  @@map("employee_download")
  @@schema("public")
}
